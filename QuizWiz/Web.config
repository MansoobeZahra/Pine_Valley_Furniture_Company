<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <!-- 
         Note: Redundant settings (compilation, sessionState, customErrors, connectionStrings) 
         are removed to avoid 'MachineToApplication' errors on Somee.com.
         They are inherited from the root Web.config.
    -->
    <pages controlRenderingCompatibilityVersion="4.0" />
  </system.web>

  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="Login.aspx" />
      </files>
    </defaultDocument>
    <modules runAllManagedModulesForAllRequests="true" />
    <staticContent>
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>
  </system.webServer>
</configuration>
