<?xml version="1.0"?>
<configuration>
  <!--
    For a description of web.config changes see http://go.microsoft.com/fwlink/?LinkId=235367.

    The following attributes can be set on the <httpRuntime> tag.
      <system.Web>
        <httpRuntime targetFramework="4.8" />
      </system.Web>
  -->
  <system.web>
    <compilation debug="false" targetFramework="4.8"/>
    <machineKey validationKey="C50B3C89CB21F4F1422FF158A5B42D0E8DB8CB5CDA1742572A487D9401E3FDE1A50D805B4B03EE7199999C70F3A2290B552F2E2307E36967B4A3469446D0898F" decryptionKey="D8B84B1F17351A2E30749E51A1867160C895A548E08C8229" validation="SHA1" decryption="AES" />
    <pages controlRenderingCompatibilityVersion="4.0" enableViewStateMac="false" viewStateEncryptionMode="Never" enableEventValidation="false" />
    <customErrors mode="Off"/>
    <httpRuntime targetFramework="4.8" />
    <sessionState
        mode="InProc"
        timeout="30"
        cookieless="UseCookies"
        cookieName="PVFC_Session"
        sqlConnectionString=""
        allowCustomSqlDatabase="false" >
    </sessionState>
  </system.web>

  <appSettings>
    <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
  </appSettings>
  
  <connectionStrings>
    <!-- 
      IMPORTANT: Right now, this is set to use your live Somee.com Database.
      Replace "YOUR_COPIED_PASSWORD" with the actual password from your Somee dashboard before uploading. 
    -->
    <add name="PineValleyDB" connectionString="workstation id=PVFC_Data.mssql.somee.com;packet size=4096;user id=maven0321_SQLLogin_1;pwd=123456789;data source=PVFC_Data.mssql.somee.com;persist security info=False;initial catalog=PVFC_Data;TrustServerCertificate=True" providerName="System.Data.SqlClient" />
    
    <!-- (If you want to test on your local PC again, comment out the line above and uncomment the line below) -->
    <!-- <add name="PineValleyDB" connectionString="Data Source=localhost;Initial Catalog=PVFC;Integrated Security=True" providerName="System.Data.SqlClient" /> -->
  </connectionStrings>
</configuration>