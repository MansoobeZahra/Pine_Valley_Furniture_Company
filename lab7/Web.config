<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <system.web>
        <compilation debug="true" targetFramework="4.8" />
        <httpRuntime targetFramework="4.8" />

        <!-- SESSION STATE MANAGEMENT -->
        <!-- Mode: InProc = stored in web server memory (fastest, lost on restart) -->
        <!-- Timeout: 30 minutes of inactivity before session expires -->
        <!-- cookieless: UseCookies = session ID stored in browser cookie -->
        <!-- httpOnlyCookies: true = JS cannot read session cookie (XSS protection) -->
        <sessionState
            mode="InProc"
            timeout="30"
            cookieless="UseCookies"
            cookieName="PVFC_Session"
            sqlConnectionString=""
            allowCustomSqlDatabase="false" >
        </sessionState>

    </system.web>

    <appSettings>
        <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
    </appSettings>

    <connectionStrings>
        <add name="PineValleyDB"
             connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=PVFC;Integrated Security=True;TrustServerCertificate=True;"
             providerName="System.Data.SqlClient" />
    </connectionStrings>
</configuration>
