<?xml version="1.0" encoding="utf-8"?>
<configuration>

        <!--
            SESSION STATE
            ─────────────────────────────────────────────
            mode      : InProc = session stored in IIS worker memory (fastest)
            timeout   : 30 min inactivity before session expires
            cookieName: the browser cookie that holds the session ID
            httpOnly  : JS cannot read the session cookie (XSS protection)
        -->

    <system.web>
        <compilation debug="true" targetFramework="4.8" />
        <httpRuntime targetFramework="4.8" />
        <sessionState
            mode="InProc"
            timeout="30"
            cookieless="UseCookies"
            cookieName="PVFC_Session"
            sqlConnectionString=""
            allowCustomSqlDatabase="false" >
        </sessionState>

    </system.web>

    <appSettings>
        <!-- Disable jQuery-based unobtrusive validation so WebForms validators work normally -->
        <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
    </appSettings>

    <!--
        DATABASE CONNECTION STRING
        ─────────────────────────────────────────────────────────────────
        Data Source        : .\SQLEXPRESS  (your local SQL Server Express)
                             If this lab needs a named instance use:
                               DESKTOP-XXXX\SQLEXPRESS  or  localhost\SQLEXPRESS
        Initial Catalog    : PVFC           (the database created by setup_database.sql)
        Integrated Security: True           (uses your Windows login — no password needed)
        TrustServerCertificate: True        (skips SSL certificate check for local dev)
        ─────────────────────────────────────────────────────────────────
        HOW TO VERIFY IN SSMS:
          1. Open SSMS
          2. Server name:  .\SQLEXPRESS
          3. Authentication: Windows Authentication
          4. Click Connect — you should see the PVFC database listed
    -->
    <connectionStrings>
        <add name="PineValleyDB"
             connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=PVFC;Integrated Security=True;TrustServerCertificate=True;"
             providerName="System.Data.SqlClient" />
    </connectionStrings>

</configuration>
